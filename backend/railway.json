{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm ci --legacy-peer-deps && npm run build 2>/dev/null || true"
  },
  "deploy": {
    "startCommand": "npm start",
    "numReplicas": 1,
    "restartPolicyMaxRetries": 5,
    "healthCheck": {
      "type": "exec",
      "command": "curl -f http://localhost:5000/api/health || exit 1",
      "interval": 10,
      "timeout": 5,
      "retries": 3
    }
  }
}
